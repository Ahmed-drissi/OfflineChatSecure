<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardDeviceRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDeviceIcon"
            android:layout_width="54dp"
            android:layout_height="54dp"
            app:cardBackgroundColor="#25334956"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivDeviceIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_phone_line"
                android:tint="@color/app_primary" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/deviceInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/signalStrengthView"
            app:layout_constraintStart_toEndOf="@id/cardDeviceIcon"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/app_on_surface_strong"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Galaxy S24" />

            <TextView
                android:id="@+id/tvDeviceAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="monospace"
                android:textColor="@color/app_on_surface_variant"
                android:textSize="11sp"
                tools:text="A1:B2:C3:D4:E5:F6" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/signalStrengthView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:gravity="bottom"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/signalBar1"
                android:layout_width="4dp"
                android:layout_height="8dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_signal_bar_active" />

            <View
                android:id="@+id/signalBar2"
                android:layout_width="4dp"
                android:layout_height="12dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_signal_bar_active" />

            <View
                android:id="@+id/signalBar3"
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_signal_bar_inactive" />

            <View
                android:id="@+id/signalBar4"
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_signal_bar_inactive" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
